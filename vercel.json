{
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    }
  ],
  "build": {
    "env": {
      "SQLITE_DB_PATH": "@sqlite_db_path",
      "OPENAI_API_KEY": "@openai_api_key",
      "ANTHROPIC_API_KEY": "@anthropic_api_key"
    }
  }
}